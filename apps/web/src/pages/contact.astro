---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../lib/site";
---

<BaseLayout title="Contact ShipAudit" description="Contact ShipAudit for founding reviews and security questions.">
  <section class="py-14 md:py-20">
    <div class="shell max-w-2xl">
      <p class="eyebrow m-0">Contact</p>
      <h1 class="mt-3 text-4xl font-black">Talk to us before or after checkout.</h1>
      <p class="text-lg text-[var(--muted)]">
        Customer, security, receipts and refunds:{" "}
        <a class="font-bold text-[var(--ink)]" href={`mailto:${site.securityEmail}`}>{site.securityEmail}</a>
      </p>
      <ul class="text-[var(--muted)]">
        <li>Pre-sales questions about scope and fit</li>
        <li>Send payment receipts after checkout</li>
        <li>Authorization and read-only materials for a paid review</li>
        <li>Refund or SLA issues per pricing terms</li>
      </ul>
      <p class="text-sm text-[var(--muted)]">
        Do not email production secrets, passwords or session tokens. {site.adminEmail} is for infrastructure
        accounts only and is not monitored as customer support.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href="/#founding-review"
          class="inline-flex h-11 items-center bg-[var(--green)] px-4 font-bold text-white no-underline"
        >
          Founding review form
        </a>
        <a
          href={`mailto:${site.securityEmail}?subject=ShipAudit%20inquiry`}
          class="inline-flex h-11 items-center border border-[var(--line)] px-4 font-bold no-underline"
        >
          Email {site.securityEmail}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
