---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../lib/site";
---

<BaseLayout
  title="ShipAudit pricing"
  description="Validation-phase ShipAudit pricing: Founding Expert Review $99. Automated products deferred."
>
  <section class="py-14 md:py-20">
    <div class="shell max-w-3xl">
      <p class="eyebrow m-0">Pricing · validation phase</p>
      <h1 class="mt-3 text-4xl font-black">Two public SKUs only.</h1>
      <p class="text-lg text-[var(--muted)]">
        Per product spec §12.1 we do not advertise automatic report prices, monitoring, or multi-tier packages
        until delivery exists and commercial gates pass. Currency is USD.
      </p>

      <div class="mt-10 grid gap-6">
        <article class="border border-[var(--line)] bg-white p-6">
          <p class="eyebrow m-0">Free</p>
          <h2 class="mt-2 text-2xl font-bold">Validation assets · $0</h2>
          <ul class="text-[var(--muted)]">
            <li>Landing page and methodology</li>
            <li>Sample report marked Example data only</li>
            <li>
              <a href="/waitlist">Automatic public scan waitlist</a> (not a live scan service; no ship date promised)
            </li>
          </ul>
        </article>

        <article class="border-2 border-[var(--green)] bg-white p-6">
          <p class="eyebrow m-0">Paid · limited</p>
          <h2 class="mt-2 text-2xl font-bold">Founding Expert Review · ${site.foundingPriceUsd}</h2>
          <p class="text-[var(--muted)]">First {site.foundingSlotsTotal} paid orders.</p>
          <ul class="text-[var(--muted)]">
            <li>1 public app and 1 primary domain</li>
            <li>Max {site.foundingMaxMinutes} minutes analysis time</li>
            <li>Written report within {site.foundingSlaBusinessDays} business days after payment + authorization + scope confirmation</li>
            <li>Public tools + fixed checklist + human judgment</li>
          </ul>
          <a
            href="/#founding-review"
            class="mt-2 inline-flex h-11 items-center bg-[var(--green)] px-4 font-bold text-white no-underline"
          >
            Start founding review
          </a>
        </article>

        <article class="border border-dashed border-[var(--line)] bg-[var(--paper)] p-6">
          <p class="eyebrow m-0">Deferred</p>
          <h2 class="mt-2 text-2xl font-bold">Not for sale yet</h2>
          <ul class="mb-0 text-[var(--muted)]">
            <li>Verified Launch Check (automated)</li>
            <li>Standard Expert Review</li>
            <li>Code &amp; Architecture Review</li>
            <li>Monitoring subscriptions</li>
            <li>Badges / “secure by” marketing marks</li>
          </ul>
        </article>
      </div>

      <p class="mt-8 text-sm text-[var(--muted)]">{site.requiredDisclaimer}</p>
    </div>
  </section>
</BaseLayout>
