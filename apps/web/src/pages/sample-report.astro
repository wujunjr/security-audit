---
import { AlertTriangle, CheckCircle2, Info, Printer, ShieldAlert } from "lucide-react";
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../lib/site";

const findings = [
  {
    icon: ShieldAlert,
    color: "var(--red)",
    badgeClass: "badge-red",
    severity: "Fix before launch",
    title: "Server-side AI credential appears in a client bundle",
    evidence:
      "A high-confidence provider key pattern was detected in example data. The displayed value is redacted.",
    fix: "Revoke the credential, move model calls behind a server endpoint, then add authentication and request limits.",
  },
  {
    icon: AlertTriangle,
    color: "var(--amber)",
    badgeClass: "badge-amber",
    severity: "Needs authorized verification",
    title: "Supabase public configuration is present",
    evidence:
      "The anon key is a public identifier and is not a confirmed secret by itself (example data).",
    fix: "Verify Row Level Security and Storage policies under explicit authorization. Do not rotate the anon key solely because it is visible.",
  },
  {
    icon: CheckCircle2,
    color: "var(--emerald)",
    badgeClass: "badge-green",
    severity: "Passed (example)",
    title: "HTTPS and primary cookie attributes",
    evidence:
      "HTTPS is reachable in this example. Observed session cookies use Secure, HttpOnly and an explicit SameSite value.",
    fix: "No immediate action for the illustrated scope.",
  },
];
---

<BaseLayout
  title="Sample ShipAudit Report (Example Data Only)"
  description="Example ShipAudit founding review layout. Not a real target assessment."
>
  <section class="py-12 md:py-20">
    <div class="shell max-w-4xl">
      <div class="no-print mb-6 flex flex-wrap items-center justify-between gap-3 fade-in-up">
        <a href="/" class="btn-ghost !px-0">← Back to ShipAudit</a>
        <button type="button" onclick="window.print()" class="btn-outline !h-10 !text-sm">
          <Printer size={17} /> Print
        </button>
      </div>

      <!-- Example notice -->
      <div class="glass-card mb-6 p-4 flex items-center gap-3 border-l-4" style="border-left-color: var(--amber);">
        <AlertTriangle size={18} className="shrink-0 text-[var(--amber)]" />
        <span class="text-sm font-bold">Example data only — this is not a verified check of a real customer domain.</span>
      </div>

      <!-- Report Container -->
      <article class="glass-card p-6 md:p-10">
        <!-- Header -->
        <header class="grid gap-6 border-b border-[var(--line)] pb-8 md:grid-cols-[1fr_auto]">
          <div>
            <div class="flex gap-2 mb-3">
              <span class="badge badge-accent">sample_report</span>
              <span class="badge badge-cyan">expert_review layout</span>
            </div>
            <h1 class="mt-0 mb-2 text-3xl font-black md:text-4xl">Demo AI Launch App</h1>
            <p class="m-0 text-[var(--ink-muted)]">
              Illustrative target: demo.example · Public homepage + configuration notes
            </p>
            <p class="mt-2 mb-0 text-sm text-[var(--ink-faint)]">
              Reviewed 11 July 2026 · Methodology {site.methodologyVersion} · Example data only
            </p>
          </div>
          <div class="grid place-items-center rounded-xl border-2 border-[var(--amber)] px-6 py-4 text-center bg-[var(--bg-deep)]">
            <span class="block text-4xl font-black gradient-text">72</span>
            <span class="text-sm font-bold text-[var(--amber)]">C</span>
            <span class="mt-2 max-w-[9rem] text-[10px] leading-tight font-semibold text-[var(--ink-faint)]">
              {site.scoreSubtitle}
            </span>
          </div>
        </header>

        <!-- Disclaimer & Scope -->
        <section class="border-b border-[var(--line)] py-8">
          <div class="flex items-start gap-3 rounded-lg bg-[var(--bg-deep)] p-4 border border-[var(--line)]">
            <Info className="mt-0.5 shrink-0 text-[var(--accent)]" />
            <p class="m-0 text-sm text-[var(--ink-muted)]">{site.requiredDisclaimer}</p>
          </div>

          <h2 class="mt-8 text-2xl font-bold">Scope / Non-goals (example)</h2>
          <div class="mt-4 grid gap-4 text-sm md:grid-cols-2">
            <div class="rounded-lg bg-[var(--bg-deep)] p-4 border border-[var(--line)]">
              <p class="m-0 font-bold text-[var(--emerald)]">Checked in this example</p>
              <ul class="mt-3 mb-0 space-y-2 list-none p-0 text-[var(--ink-muted)]">
                <li class="flex gap-2"><span class="text-[var(--emerald)]">✓</span> Public HTTPS reachability (illustrated)</li>
                <li class="flex gap-2"><span class="text-[var(--emerald)]">✓</span> Selected response-header hygiene notes</li>
                <li class="flex gap-2"><span class="text-[var(--emerald)]">✓</span> Client-visible configuration patterns (fictional)</li>
              </ul>
            </div>
            <div class="rounded-lg bg-[var(--bg-deep)] p-4 border border-[var(--line)]">
              <p class="m-0 font-bold text-[var(--red)]">Not checked</p>
              <ul class="mt-3 mb-0 space-y-2 list-none p-0 text-[var(--ink-muted)]">
                <li class="flex gap-2"><span class="text-[var(--red)]">✗</span> Authenticated sessions, source code, infra</li>
                <li class="flex gap-2"><span class="text-[var(--red)]">✗</span> Port scans, exploitation, directory brute force</li>
                <li class="flex gap-2"><span class="text-[var(--red)]">✗</span> Compliance certification</li>
              </ul>
            </div>
          </div>

          <h2 class="mt-8 text-2xl font-bold">Launch Decision (example)</h2>
          <p class="text-lg text-[var(--ink-muted)] leading-relaxed">
            Do not launch with the illustrated AI credential. Revoke it and move the provider call server-side.
            The Supabase configuration requires an authorized RLS check before it can be classified.
          </p>
        </section>

        <!-- Findings -->
        <section class="grid gap-4 py-8">
          <h2 class="m-0 text-2xl font-bold">Findings (example)</h2>
          {findings.map(({ icon: Icon, color, badgeClass, severity, title, evidence, fix }) => (
            <article class="rounded-xl border border-[var(--line)] bg-[var(--bg-deep)] p-5 hover:border-[var(--line-focus)] transition-colors" style={`border-left: 3px solid ${color};`}>
              <div class="flex items-start gap-3">
                <Icon style={{ color }} className="mt-1 shrink-0" />
                <div>
                  <span class={`badge ${badgeClass} mb-2`}>{severity}</span>
                  <h3 class="mt-1 mb-3 text-lg font-bold">{title}</h3>
                  <dl class="m-0 grid gap-3 text-sm">
                    <div>
                      <dt class="font-bold text-[var(--ink)]">Evidence</dt>
                      <dd class="m-0 text-[var(--ink-muted)] mt-1">{evidence}</dd>
                    </div>
                    <div>
                      <dt class="font-bold text-[var(--ink)]">Recommended Action</dt>
                      <dd class="m-0 text-[var(--ink-muted)] mt-1">{fix}</dd>
                    </div>
                  </dl>
                </div>
              </div>
            </article>
          ))}
        </section>

        <!-- Footer -->
        <footer class="border-t border-[var(--line)] pt-6 text-sm text-[var(--ink-muted)]">
          <p class="m-0">
            <strong class="text-[var(--ink)]">Signature line (real reviews):</strong>{" "}
            {site.reviewerLine}
          </p>
          <p class="mt-2 mb-0">
            A reviewed report confirms that the listed checks were performed within scope. It does not certify the
            application as secure. This page uses example data only.
          </p>
        </footer>
      </article>
    </div>
  </section>
</BaseLayout>
