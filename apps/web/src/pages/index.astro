---
import { ArrowRight, BadgeCheck, Clock3, FileSearch, ListChecks, ShieldCheck } from "lucide-react";
import { ReviewRequestForm } from "../components/ReviewRequestForm";
import BaseLayout from "../layouts/BaseLayout.astro";
import { isPaymentConfigured, site } from "../lib/site";

const paymentReady = isPaymentConfigured();

const deliverables = [
  ["Written reviewed report", "Scope, evidence notes, prioritized actions and unknowns — within stated limits."],
  ["Public-surface focus", "Observable HTTP hygiene and configuration review. No exploit attempts."],
  ["Human judgment", "False-positive removal and a clear fix-before-launch versus ship-with-risk note."],
];
---

<BaseLayout
  title="ShipAudit — Pre-launch HTTP security hygiene for web apps"
  description="Founding expert review of public HTTP security hygiene for indie and AI-assisted web apps. Not a vulnerability scan or certification."
>
  <div class="border-b border-[var(--line)] bg-[#fdfdfc] py-4 text-sm no-print">
    <div class="shell flex flex-col md:flex-row md:items-center justify-between gap-3">
      <div class="flex items-start gap-3">
        <span class="inline-block shrink-0 bg-[var(--amber)] px-2 py-0.5 text-xs font-bold text-white uppercase rounded-sm">
          Notice / 公告
        </span>
        <div class="text-[var(--ink)] leading-relaxed">
          <p class="m-0 font-semibold">
            见己*内在地图已经迁移至 <a href="https://www.jianji.net" target="_blank" rel="noopener noreferrer" class="underline text-[var(--green)] hover:text-[var(--green-dark)] font-bold">www.jianji.net</a>。本网站已改版为网络安全专业站点。
          </p>
          <p class="m-0 text-xs text-[var(--muted)] mt-0.5">
            Jianji * Inner Map has been migrated to <a href="https://www.jianji.net" target="_blank" rel="noopener noreferrer" class="underline text-[var(--green)] hover:text-[var(--green-dark)]">www.jianji.net</a>. This website is now a cybersecurity professional website.
          </p>
        </div>
      </div>
    </div>
  </div>

  <section class="border-b border-[var(--line)] bg-white py-14 md:py-20">
    <div class="shell grid items-start gap-12 lg:grid-cols-[1.15fr_0.85fr]">
      <div>
        <p class="eyebrow m-0">Validation phase · Expert review first</p>
        <h1 class="my-5 max-w-3xl text-4xl leading-[1.05] font-black md:text-5xl">
          Pre-launch HTTP security hygiene — with a human in the loop.
        </h1>
        <p class="max-w-2xl text-lg text-[var(--muted)] md:text-xl">
          ShipAudit helps founders shipping with Lovable, Bolt, Replit, Cursor and similar tools understand
          <strong class="font-semibold text-[var(--ink)]">public configuration risk</strong> before launch.
          Today we sell a scoped <strong class="font-semibold text-[var(--ink)]">Founding Expert Review</strong>.
          Our own automated scanner is <strong class="font-semibold text-[var(--ink)]">not live yet</strong>.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="#founding-review" class="inline-flex h-12 items-center gap-2 bg-[var(--green)] px-5 font-bold text-white no-underline hover:bg-[var(--green-dark)]">
            Get founding review (${site.foundingPriceUsd}) <ArrowRight size={18} />
          </a>
          <a href="/sample-report" class="inline-flex h-12 items-center border border-[var(--line)] px-5 font-bold no-underline hover:bg-[var(--paper)]">
            View sample report
          </a>
          <a href="/waitlist" class="inline-flex h-12 items-center border border-[var(--line)] px-5 font-bold no-underline hover:bg-[var(--paper)]">
            Auto-scan waitlist
          </a>
        </div>
        <p class="mt-5 flex items-start gap-2 text-sm text-[var(--muted)]">
          <ShieldCheck size={17} className="mt-0.5 shrink-0 text-[var(--green)]" />
          {site.requiredDisclaimer}
        </p>
      </div>

      <aside class="border border-[var(--line)] bg-[var(--paper)] p-6 md:p-8" aria-label="What is available now">
        <p class="eyebrow m-0">Available now</p>
        <h2 class="mb-3 text-2xl font-bold">Founding Expert Review — ${site.foundingPriceUsd}</h2>
        <ul class="m-0 grid list-none gap-3 p-0 text-sm">
          <li class="flex gap-2"><ListChecks size={18} className="shrink-0 text-[var(--green)]" /> First {site.foundingSlotsTotal} paid orders only</li>
          <li class="flex gap-2"><FileSearch size={18} className="shrink-0 text-[var(--green)]" /> 1 public app · 1 primary domain · max {site.foundingMaxMinutes} minutes analysis</li>
          <li class="flex gap-2"><Clock3 size={18} className="shrink-0 text-[var(--green)]" /> Written report within {site.foundingSlaBusinessDays} business days after payment, authorization and scope confirmation</li>
          <li class="flex gap-2"><BadgeCheck size={18} className="shrink-0 text-[var(--green)]" /> Uses public tools + a fixed checklist + human judgment — not ShipAudit auto-scan</li>
        </ul>
        <p class="mt-5 mb-0 text-sm text-[var(--muted)]">
          Payment status:{" "}
          {paymentReady ? (
            <span class="font-bold text-[var(--green)]">Checkout link configured</span>
          ) : (
            <span class="font-bold text-[var(--amber)]">Checkout link pending (Creem primary / Stripe fallback)</span>
          )}
        </p>
        <a href="/pricing" class="mt-4 inline-block font-bold text-[var(--green)]">Full pricing &amp; deferred SKUs →</a>
      </aside>
    </div>
  </section>

  <section class="py-14 md:py-20">
    <div class="shell">
      <p class="eyebrow m-0">What you receive</p>
      <h2 class="section-title mt-3 max-w-3xl">A scoped launch decision, not a wall of scanner noise.</h2>
      <div class="mt-9 grid gap-px bg-[var(--line)] md:grid-cols-3">
        {deliverables.map(([title, copy], index) => (
          <article class="bg-white p-6">
            {index === 0 && <FileSearch className="mb-5 text-[var(--blue)]" />}
            {index === 1 && <ShieldCheck className="mb-5 text-[var(--green)]" />}
            {index === 2 && <BadgeCheck className="mb-5 text-[var(--amber)]" />}
            <h3 class="text-xl font-bold">{title}</h3>
            <p class="mb-0 text-[var(--muted)]">{copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="border-y border-[var(--line)] bg-white py-14 md:py-20" id="scope">
    <div class="shell max-w-3xl">
      <p class="eyebrow m-0">Scope / Non-goals</p>
      <h2 class="section-title mt-3">Honest boundaries for this validation phase</h2>
      <div class="mt-8 grid gap-6 md:grid-cols-2">
        <div class="border border-[var(--line)] p-5">
          <h3 class="mt-0 text-lg font-bold">In scope (founding review)</h3>
          <ul class="mb-0 text-sm text-[var(--muted)]">
            <li>Public HTTP surface of one app / one primary domain</li>
            <li>Observable hygiene: HTTPS, headers, cookies, obvious public misconfig</li>
            <li>Customer-supplied read-only screenshots or architecture notes</li>
            <li>Prioritized actions and false-positive call-outs</li>
          </ul>
        </div>
        <div class="border border-[var(--line)] p-5">
          <h3 class="mt-0 text-lg font-bold">Out of scope</h3>
          <ul class="mb-0 text-sm text-[var(--muted)]">
            <li>Vulnerability exploitation, port scans, directory brute force</li>
            <li>Authenticated / login-session testing</li>
            <li>Full API or source-code audit</li>
            <li>Compliance certification (等保, GDPR “pass”, etc.)</li>
            <li>ShipAudit-branded automated public scanner (not shipped yet)</li>
          </ul>
        </div>
      </div>
      <p class="mt-6 text-sm text-[var(--muted)]">{site.requiredDisclaimer}</p>
    </div>
  </section>

  <section class="py-14 md:py-20" id="founding-review">
    <div class="shell grid gap-8 lg:grid-cols-[0.85fr_1.15fr]">
      <div>
        <p class="eyebrow m-0">Founding offer</p>
        <h2 class="section-title mt-3">Founding Expert Review — ${site.foundingPriceUsd}</h2>
        <p class="text-lg text-[var(--muted)]">
          Limited to the first {site.foundingSlotsTotal} paid orders. After payment and scope confirmation we deliver a written reviewed report within {site.foundingSlaBusinessDays} business days.
        </p>
        <ul class="grid list-none gap-3 p-0 text-sm">
          <li class="flex gap-2"><ShieldCheck size={18} className="shrink-0 text-[var(--green)]" /> No passwords, cookies, or production secrets accepted</li>
          <li class="flex gap-2"><FileSearch size={18} className="shrink-0 text-[var(--green)]" /> We do not modify your code</li>
          <li class="flex gap-2"><Clock3 size={18} className="shrink-0 text-[var(--green)]" /> Extra scope is quoted separately — not squeezed into {site.foundingMaxMinutes} minutes</li>
        </ul>
        <p class="mt-6 text-sm text-[var(--muted)]">
          Questions before paying? Email{" "}
          <a class="font-bold text-[var(--ink)]" href={`mailto:${site.securityEmail}`}>{site.securityEmail}</a>.
          Mailto is for pre-sales only and is not proof of payment.
        </p>
      </div>
      <div>
        <ReviewRequestForm client:load paymentConfigured={paymentReady} />
      </div>
    </div>
  </section>
</BaseLayout>
