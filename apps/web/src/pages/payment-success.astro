---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../lib/site";
---

<BaseLayout
  title="Payment received — ShipAudit"
  description="What happens after you pay for a ShipAudit Founding Expert Review."
>
  <section class="py-14 md:py-20">
    <div class="shell max-w-2xl">
      <p class="eyebrow m-0">Checkout</p>
      <h1 class="mt-3 text-4xl font-black">Thanks — next we confirm scope.</h1>
      <p class="text-lg text-[var(--muted)]">
        If you completed payment with our merchant link, keep the receipt. Analysis does not start until we confirm
        authorization and scope by email.
      </p>

      <ol class="grid list-decimal gap-3 pl-5 text-[var(--muted)]">
        <li>
          Email your receipt and app URL to{" "}
          <a class="font-bold text-[var(--ink)]" href={`mailto:${site.securityEmail}`}>{site.securityEmail}</a>
          if the processor did not already capture them.
        </li>
        <li>We confirm the single domain/app and public-surface limits (max {site.foundingMaxMinutes} minutes).</li>
        <li>
          Written report within {site.foundingSlaBusinessDays} business days after confirmation (SLA pauses if you
          delay materials).
        </li>
      </ol>

      <div class="mt-8 border border-[var(--line)] bg-white p-5 text-sm">
        <p class="mt-0 font-bold text-[var(--ink)]">Refunds (summary)</p>
        <ul class="mb-0 text-[var(--muted)]">
          <li>Full refund if you cancel before work starts, or we cannot begin within agreed scope.</li>
          <li>If we miss the {site.foundingSlaBusinessDays}-business-day delivery window for our reasons: delay or full refund.</li>
          <li>After delivery: corrections first; refund if material scope error cannot be fixed.</li>
        </ul>
      </div>

      <p class="mt-6 text-sm text-[var(--muted)]">
        Did not pay yet?{" "}
        <a class="font-bold text-[var(--ink)]" href="/#founding-review">Return to founding review</a>.
      </p>
    </div>
  </section>
</BaseLayout>
